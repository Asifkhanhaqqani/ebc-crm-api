# Port the Express server listens on.
PORT=3001

# development | production | test
NODE_ENV=development

# Supabase project URL, from Supabase Dashboard → Settings → API.
SUPABASE_URL=https://your-project.supabase.co

# Service role key — bypasses all RLS. NEVER commit this, NEVER send it to the
# frontend. Used only by the backend for privileged reads/writes.
SUPABASE_SERVICE_ROLE_KEY=

# Anon key — safe to expose to browsers. Used server-side here only to verify
# incoming user JWTs via supabase.auth.getUser(token).
SUPABASE_ANON_KEY=

# JWT signing secret, from Supabase Dashboard → Settings → API.
SUPABASE_JWT_SECRET=

# Origin allowed by CORS — the deployed/local frontend URL.
FRONTEND_URL=http://localhost:5173

# Resend API key, from resend.com dashboard. Used for all outbound email.
RESEND_API_KEY=

# From address used for outbound email (must be a verified Resend domain).
FROM_EMAIL=crm@ebc-fire.org

# Shared secret required in the X-Cron-Secret header when the shift-packet
# cron job is invoked over HTTP (Railway also sets this for scheduled runs).
CRON_SECRET=

# winston log level: error | warn | info | debug
LOG_LEVEL=info
